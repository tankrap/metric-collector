COLLECTOR_DOMAIN=metrics.example.com
COLLECTOR_HTTP_PORT=80
# Used by repository smoke scripts when targeting this stack.
COLLECTOR_BASE_URL=https://metrics.example.com

# Generate with: openssl rand -base64 32
COLLECTOR_UPLOAD_TOKEN=replace-with-upload-token
COLLECTOR_ADMIN_TOKEN=replace-with-admin-token

# Default: 1 MiB. The collector should reject larger bodies too.
COLLECTOR_MAX_BODY_BYTES=1048576

# Default: 60 upload attempts per client IP per 60 second window.
COLLECTOR_RATE_LIMIT_REQUESTS=60
COLLECTOR_RATE_LIMIT_WINDOW_SECONDS=60

# Path inside the collector container. Keep this under /data for volume persistence.
COLLECTOR_DB=/data/collector.sqlite3

# Compose builds ../../server/collector by default and tags it with this name.
COLLECTOR_IMAGE=metric-taker-collector:local

# Compose builds the Caddy image from deploy/collector/Caddy.Dockerfile.
CADDY_IMAGE=metric-taker-caddy:local
