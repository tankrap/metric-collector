{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vc-tokmeter.local/schemas/upload-payload-v1.schema.json",
  "title": "vc-tokmeter opt-in upload payload v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact_type",
    "created_at",
    "client",
    "consent",
    "study",
    "session",
    "metrics",
    "redaction"
  ],
  "properties": {
    "schema_version": {
      "const": "vc-tokmeter.upload.v1"
    },
    "artifact_type": {
      "const": "vc-tokmeter.upload"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "Client-side upload payload creation time."
    },
    "upload_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_.:-]{8,128}$"
    },
    "client": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tokmeter_version", "surface", "platform"],
      "properties": {
        "tokmeter_version": {
          "type": "string",
          "pattern": "^[0-9A-Za-z_.:+-]{1,64}$"
        },
        "surface": {
          "type": "string",
          "enum": [
            "codex-cli",
            "codex-tui",
            "codex-exec",
            "claude-code",
            "claude-desktop",
            "mcp-desktop",
            "other"
          ]
        },
        "surface_detail": {
          "type": "string",
          "maxLength": 64,
          "pattern": "^[A-Za-z0-9_.:+-]+$"
        },
        "platform": {
          "type": "object",
          "additionalProperties": false,
          "required": ["os", "arch"],
          "properties": {
            "os": {
              "type": "string",
              "enum": ["macos", "linux", "windows", "unknown"]
            },
            "arch": {
              "type": "string",
              "enum": ["arm64", "x86_64", "aarch64", "unknown"]
            }
          }
        }
      }
    },
    "consent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["upload_opt_in", "consent_version"],
      "properties": {
        "upload_opt_in": {
          "const": true
        },
        "consent_version": {
          "const": "2026-07-05"
        },
        "tester_alias": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80,
          "pattern": "^[A-Za-z0-9_.@:+-]+$"
        },
        "contact_ok": {
          "type": "boolean"
        }
      }
    },
    "study": {
      "type": "object",
      "additionalProperties": false,
      "required": ["study_id", "protocol_version"],
      "properties": {
        "study_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_.:-]{1,80}$"
        },
        "protocol_version": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_.:-]{1,40}$"
        },
        "cohort": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_.:-]{1,80}$"
        }
      }
    },
    "session": {
      "type": "object",
      "additionalProperties": false,
      "required": ["session_id_hash", "time_bucket_utc", "duration_seconds"],
      "properties": {
        "session_id_hash": {
          "type": "string",
          "pattern": "^[a-f0-9]{12,64}$"
        },
        "repo_hash": {
          "type": "string",
          "pattern": "^[a-f0-9]{12,64}$"
        },
        "time_bucket_utc": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:00:00Z$",
          "description": "Coarse UTC hour bucket; exact local times stay local."
        },
        "duration_seconds": {
          "type": "integer",
          "minimum": 0
        },
        "timezone_offset_minutes": {
          "type": "integer",
          "minimum": -840,
          "maximum": 840
        }
      }
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidence_grade",
        "token_fidelity",
        "summary",
        "session_git_share",
        "token_sources",
        "git_workflow"
      ],
      "properties": {
        "evidence_grade": {
          "type": "string",
          "enum": ["O", "P"]
        },
        "token_fidelity": {
          "type": "string",
          "enum": ["exact", "estimated", "mixed", "unknown"]
        },
        "summary": {
          "$ref": "#/$defs/summary"
        },
        "session_git_share": {
          "$ref": "#/$defs/session_git_share"
        },
        "token_sources": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/token_source"
          }
        },
        "git_workflow": {
          "$ref": "#/$defs/git_workflow"
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "observational_only",
              "partial_capture",
              "mixed_fidelity",
              "unknown_token_source"
            ]
          }
        }
      }
    },
    "redaction": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_artifact", "digest_hex_chars", "private_data_policy"],
      "properties": {
        "source_artifact": {
          "const": "report-share"
        },
        "digest_hex_chars": {
          "type": "integer",
          "minimum": 8,
          "maximum": 24
        },
        "salt_scope": {
          "type": "string",
          "enum": ["client-local", "session-local", "tester-local"]
        },
        "private_data_policy": {
          "const": "aggregate-only-no-raw-content"
        }
      }
    }
  },
  "$defs": {
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "runs",
        "tasks",
        "events",
        "total_tokens",
        "input_tokens",
        "output_tokens",
        "cache_read_tokens",
        "cache_write_tokens",
        "bytes"
      ],
      "properties": {
        "runs": { "type": "integer", "minimum": 0 },
        "tasks": { "type": "integer", "minimum": 0 },
        "events": { "type": "integer", "minimum": 0 },
        "total_tokens": { "type": "integer", "minimum": 0 },
        "input_tokens": { "type": "integer", "minimum": 0 },
        "output_tokens": { "type": "integer", "minimum": 0 },
        "cache_read_tokens": { "type": "integer", "minimum": 0 },
        "cache_write_tokens": { "type": "integer", "minimum": 0 },
        "bytes": { "type": "integer", "minimum": 0 }
      }
    },
    "session_git_share": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_tokens",
        "git_tokens",
        "non_git_tokens",
        "git_token_share",
        "fidelity"
      ],
      "properties": {
        "total_tokens": { "type": "integer", "minimum": 0 },
        "git_tokens": { "type": "integer", "minimum": 0 },
        "non_git_tokens": { "type": "integer", "minimum": 0 },
        "git_token_share": { "type": "number", "minimum": 0, "maximum": 1 },
        "fidelity": {
          "type": "string",
          "enum": ["exact", "estimated", "mixed", "unknown"]
        }
      }
    },
    "token_source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "events", "total_tokens", "token_share"],
      "properties": {
        "source": {
          "type": "string",
          "enum": [
            "codex exec exact usage",
            "proxy exact usage",
            "proxy estimate",
            "mcp tool",
            "mcp tool request",
            "mcp tool response",
            "hook",
            "hook request",
            "hook response",
            "other"
          ]
        },
        "events": { "type": "integer", "minimum": 0 },
        "total_tokens": { "type": "integer", "minimum": 0 },
        "input_tokens": { "type": "integer", "minimum": 0 },
        "output_tokens": { "type": "integer", "minimum": 0 },
        "cache_read_tokens": { "type": "integer", "minimum": 0 },
        "cache_write_tokens": { "type": "integer", "minimum": 0 },
        "bytes": { "type": "integer", "minimum": 0 },
        "token_share": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "git_workflow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["totals", "action_subtypes"],
      "properties": {
        "totals": {
          "$ref": "#/$defs/summary"
        },
        "action_subtypes": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "action_subtype",
              "direction",
              "operation_class",
              "events",
              "total_tokens",
              "bytes"
            ],
            "properties": {
              "action_subtype": {
                "type": "string",
                "enum": [
                  "git.status",
                  "git.diff",
                  "git.log",
                  "git.show",
                  "git.branch",
                  "git.commit",
                  "git.other",
                  "vc.status",
                  "vc.diff",
                  "vc.log",
                  "vc.other"
                ]
              },
              "direction": {
                "type": "string",
                "enum": ["request", "response", "summary", "unknown"]
              },
              "operation_class": {
                "type": "string",
                "enum": [
                  "version_control",
                  "file_interaction",
                  "generated_context",
                  "other"
                ]
              },
              "events": { "type": "integer", "minimum": 0 },
              "total_tokens": { "type": "integer", "minimum": 0 },
              "input_tokens": { "type": "integer", "minimum": 0 },
              "output_tokens": { "type": "integer", "minimum": 0 },
              "cache_read_tokens": { "type": "integer", "minimum": 0 },
              "cache_write_tokens": { "type": "integer", "minimum": 0 },
              "bytes": { "type": "integer", "minimum": 0 },
              "token_share": { "type": "number", "minimum": 0, "maximum": 1 }
            }
          }
        }
      }
    }
  }
}
